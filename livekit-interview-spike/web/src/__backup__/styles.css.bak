:root {
  color: #17221d;
  background: #edf3ed;
  font-family: "Aptos", "Microsoft YaHei UI", sans-serif;
}

* {
  box-sizing: border-box;
}

/* --- 分析依据卡片 --- */
.analysis-notes-card {
  margin-top: 16px;
  padding: 14px 16px;
  background: #f4f8f4;
  border-radius: 10px;
  border: 1px solid #d8e4d8;
}
.analysis-notes-card > strong {
  display: block;
  font-size: 13px;
  margin-bottom: 8px;
  color: #3b5e3b;
}
.analysis-notes-card ul {
  margin: 0;
  padding-left: 18px;
  font-size: 13px;
  color: #4a5c4a;
  line-height: 1.7;
}
.analysis-notes-card details {
  margin-top: 12px;
  font-size: 13px;
}
.analysis-notes-card summary {
  cursor: pointer;
  color: #3b5e3b;
  font-weight: 600;
  margin-bottom: 10px;
}
.competency-detail-grid {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 8px;
}
.competency-detail-item {
  padding: 10px 12px;
  background: #fff;
  border-radius: 8px;
  border: 1px solid #e2ece2;
}
.competency-detail-item strong {
  display: block;
  font-size: 14px;
  color: #1a2e1a;
}
.competency-detail-item span {
  font-size: 12px;
  color: #6b8b6b;
  margin-left: 0;
}
.competency-detail-item p {
  margin: 4px 0;
  font-size: 13px;
  color: #4a5c4a;
}
.competency-detail-item small {
  display: block;
  font-size: 12px;
  color: #7a9a7a;
  margin-top: 2px;
}

body {
  margin: 0;
  min-height: 100vh;
  background:
    radial-gradient(circle at 18% 12%, rgba(46, 111, 87, 0.18), transparent 28%),
    radial-gradient(circle at 84% 18%, rgba(190, 112, 63, 0.13), transparent 24%),
    linear-gradient(180deg, #fbfcf7 0%, #e8f0e8 100%);
}

button {
  border: 0;
  border-radius: 999px;
  padding: 0.85rem 1.25rem;
  color: #fbfcf7;
  background: #214f40;
  font: inherit;
  font-weight: 750;
  cursor: pointer;
}

button:disabled {
  opacity: 0.6;
  cursor: wait;
}

.secondary-button {
  color: #214f40;
  background: rgba(33, 79, 64, 0.1);
}

.danger-button {
  color: #fff9f4;
  background: #9f3f31;
}

.ghost-button {
  color: #214f40;
  background: rgba(251, 252, 247, 0.72);
  box-shadow: inset 0 0 0 1px rgba(33, 79, 64, 0.12);
}

.landing,
.room-shell {
  min-height: 100vh;
  max-width: 1120px;
  margin: 0 auto;
  padding: clamp(1.2rem, 3vw, 2.4rem);
}

.landing {
  display: block;
}

.hero-card {
  width: min(100%, 42rem);
  padding: clamp(1.5rem, 5vw, 3.5rem);
  border: 1px solid rgba(33, 79, 64, 0.15);
  border-radius: 1.35rem;
  background: rgba(251, 252, 247, 0.82);
  box-shadow: 0 28px 70px rgba(32, 47, 39, 0.11);
}

.product-shell {
  width: min(1440px, 100%);
  min-height: 100vh;
  margin: 0 auto;
  padding: clamp(1rem, 2.4vw, 2rem);
}

.home-dashboard,
.report-page {
  display: grid;
  gap: 1rem;
  align-items: start;
  width: min(1180px, 100%);
  margin: 0 auto;
}

.home-workspace {
  display: grid;
  grid-template-columns: minmax(16rem, 0.42fr) minmax(0, 1fr);
  gap: 1rem;
  align-items: start;
  min-height: calc(100vh - 4rem);
}

.home-nav-card {
  position: sticky;
  top: 1rem;
  display: grid;
  align-content: start;
  gap: 0.85rem;
  min-height: calc(100vh - 4rem);
  padding: clamp(0.85rem, 1.6vw, 1.1rem);
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 1.35rem;
  background:
    radial-gradient(circle at 20% 12%, rgba(196, 110, 68, 0.16), transparent 24%),
    linear-gradient(180deg, rgba(251, 252, 247, 0.92), rgba(226, 237, 226, 0.78));
  box-shadow: 0 22px 58px rgba(32, 47, 39, 0.1);
}

.home-nav-brand {
  color: #173c31;
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 900;
  letter-spacing: -0.03em;
  line-height: 0.98;
}

.home-nav-list {
  display: grid;
  gap: 0.55rem;
  align-content: start;
  margin-top: 0.35rem;
}

.home-nav-list button {
  display: grid;
  gap: 0.18rem;
  width: 100%;
  padding: 0.82rem 0.9rem;
  border-radius: 0.9rem;
  color: #214f40;
  background: rgba(255, 255, 255, 0.54);
  box-shadow: inset 0 0 0 1px rgba(33, 79, 64, 0.08);
  text-align: left;
}

.home-nav-list button[data-active="true"] {
  color: #fbfcf7;
  background: #214f40;
  box-shadow: 0 14px 30px rgba(33, 79, 64, 0.18);
}

.home-nav-list span {
  font-size: 0.78rem;
  opacity: 0.72;
}

.home-stage {
  display: grid;
  gap: 1rem;
  min-width: 0;
}

.home-focus-card {
  display: grid;
  align-content: center;
  gap: 1rem;
  min-height: calc(100vh - 4rem);
  overflow: hidden;
  background:
    radial-gradient(circle at 85% 18%, rgba(196, 110, 68, 0.14), transparent 22%),
    radial-gradient(circle at 12% 80%, rgba(33, 79, 64, 0.12), transparent 25%),
    rgba(251, 252, 247, 0.84);
}

.home-focus-card h2 {
  max-width: 44rem;
  margin: 0;
  color: #173c31;
  font-size: clamp(2rem, 4.4vw, 4.6rem);
  line-height: 0.98;
  letter-spacing: -0.05em;
}

.home-primary-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
}

.home-status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  margin-top: 0.4rem;
}

.home-status-row span {
  border-radius: 999px;
  padding: 0.38rem 0.62rem;
  color: #607069;
  background: rgba(255, 255, 255, 0.56);
  font-size: 0.82rem;
  font-weight: 800;
}

.reconnect-screen {
  display: grid;
  place-items: start;
  align-content: center;
  gap: 0.85rem;
  width: min(42rem, 100%);
  min-height: calc(100vh - 4rem);
  margin: 0 auto;
  padding: clamp(1.4rem, 4vw, 2.4rem);
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 1.35rem;
  background:
    radial-gradient(circle at 82% 18%, rgba(196, 110, 68, 0.14), transparent 26%),
    linear-gradient(135deg, rgba(251, 252, 247, 0.94), rgba(226, 237, 226, 0.82));
  box-shadow: 0 24px 60px rgba(32, 47, 39, 0.1);
}

.reconnect-screen h1 {
  margin: 0;
  color: #173c31;
  font-size: clamp(2rem, 4vw, 3.4rem);
  line-height: 1;
}

.reconnect-screen p {
  margin: 0;
  color: #607069;
  line-height: 1.6;
}

.home-hero {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 1rem;
  padding: clamp(1.4rem, 3vw, 2.4rem);
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 1.5rem;
  background:
    radial-gradient(circle at 10% 20%, rgba(196, 110, 68, 0.14), transparent 24%),
    linear-gradient(135deg, rgba(251, 252, 247, 0.92), rgba(226, 237, 226, 0.82));
  box-shadow: 0 24px 60px rgba(32, 47, 39, 0.1);
}

.home-actions {
  display: grid;
  align-content: center;
  gap: 0.65rem;
  min-width: 13rem;
}

.home-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
}

.home-grid.two-columns {
  grid-template-columns: 1fr 1fr;
}

.home-card,
.wizard-card {
  padding: clamp(1rem, 2vw, 1.35rem);
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 1.15rem;
  background: rgba(251, 252, 247, 0.82);
  box-shadow: 0 18px 48px rgba(32, 47, 39, 0.08);
}

.metric-card {
  display: grid;
  gap: 0.3rem;
}

.metric-card span,
.section-title span {
  color: #87948e;
  font-size: 0.78rem;
  font-weight: 850;
}

.metric-card strong {
  color: #214f40;
  font-size: clamp(1.6rem, 3vw, 2.5rem);
}

.metric-card p,
.section-title p {
  margin: 0;
  color: #607069;
  line-height: 1.5;
}

.section-title {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.8rem;
  margin-bottom: 0.75rem;
}

.section-title strong {
  color: #214f40;
  font-size: 1.12rem;
}

.text-button {
  border-radius: 999px;
  padding: 0.32rem 0.65rem;
  color: #214f40;
  background: rgba(33, 79, 64, 0.08);
  font-size: 0.85rem;
}

.history-list {
  display: grid;
  gap: 0.55rem;
}

.history-card {
  align-self: start;
}

.history-card .section-title {
  margin-bottom: 0.55rem;
}

.history-list button,
.history-list div {
  display: grid;
  grid-template-columns: minmax(8rem, 1fr) minmax(12rem, 1.2fr) auto;
  gap: 0.8rem;
  align-items: center;
  padding: 0.75rem;
  border-radius: 0.85rem;
  color: #214f40;
  background: rgba(255, 255, 255, 0.56);
  text-align: left;
}

.history-list span,
.history-list time,
.history-list p {
  margin: 0;
  color: #607069;
  font-size: 0.86rem;
}

.wizard-shell {
  display: grid;
  gap: 1.2rem;
  min-height: calc(100vh - 4rem);
  align-content: start;
}

.wizard-topbar {
  position: sticky;
  top: 0.7rem;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: min(52rem, 100%);
  margin: 0 auto;
  color: #607069;
  font-weight: 850;
}

.wizard-home-button {
  padding: 0.48rem 0.82rem;
  color: #214f40;
  background: rgba(251, 252, 247, 0.78);
  box-shadow: inset 0 0 0 1px rgba(33, 79, 64, 0.14), 0 10px 24px rgba(32, 47, 39, 0.06);
  font-size: 0.86rem;
}

.wizard-panel {
  display: grid;
  gap: 0;
  width: min(52rem, 100%);
  margin: 0 auto;
}

.wizard-progress {
  height: 0.22rem;
  overflow: hidden;
  border-radius: 999px 999px 0 0;
  background: rgba(33, 79, 64, 0.1);
}

.wizard-progress i {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: #214f40;
  transition: width 220ms ease;
}

.wizard-card {
  display: grid;
  gap: 1rem;
  min-height: min(32rem, calc(100vh - 11rem));
  align-content: start;
  padding: clamp(1.45rem, 3.2vw, 2.35rem);
  border-radius: 0 0 1.35rem 1.35rem;
}

.wizard-card input {
  width: 100%;
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 0.75rem;
  padding: 0.7rem 0.75rem;
  color: #214f40;
  background: rgba(255, 255, 255, 0.68);
  font: inherit;
  font-weight: 750;
}

.choice-grid,
.confirm-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.75rem;
}

.choice-grid button {
  display: grid;
  gap: 0.35rem;
  min-height: 6rem;
  border-radius: 1rem;
  padding: 0.9rem;
  color: #214f40;
  background: rgba(255, 255, 255, 0.56);
  text-align: left;
  box-shadow: inset 0 0 0 1px rgba(33, 79, 64, 0.1);
}

.choice-grid button[data-active="true"] {
  color: #fbfcf7;
  background: #214f40;
}

.choice-grid span {
  font-size: 0.86rem;
  opacity: 0.78;
}

.advanced-card {
  padding: 0.8rem;
  border-radius: 1rem;
  background: rgba(255, 255, 255, 0.46);
}

.advanced-card summary {
  cursor: pointer;
  color: #214f40;
  font-weight: 850;
}

.wizard-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 0.7rem;
  padding: 0.85rem;
  border-radius: 1rem;
  background: rgba(251, 252, 247, 0.74);
}

.wizard-actions > span {
  margin-right: auto;
  color: #87948e;
  font-size: 0.85rem;
  font-weight: 850;
}

.transcript-history div {
  grid-template-columns: 4rem 1fr auto;
}

.debug-back-button {
  margin: 0 0 0.8rem;
}

.setup-page {
  width: 100%;
  max-width: none;
  min-height: 100vh;
  padding: clamp(0.8rem, 1.8vw, 1.25rem);
  overflow: visible;
}

.training-dock {
  display: grid;
  grid-template-columns: minmax(18rem, 0.62fr) minmax(0, 1.75fr);
  gap: clamp(0.8rem, 1.6vw, 1.2rem);
  align-items: start;
  min-height: auto;
}

.setup-sidebar {
  position: sticky;
  top: clamp(0.8rem, 1.8vw, 1.25rem);
  max-height: calc(100vh - clamp(1.6rem, 3.6vw, 2.5rem));
  min-height: auto;
  display: grid;
  align-content: start;
  gap: 0.7rem;
  padding: clamp(1rem, 1.8vw, 1.35rem);
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 1.6rem;
  background:
    radial-gradient(circle at 24% 20%, rgba(196, 110, 68, 0.18), transparent 26%),
    radial-gradient(circle at 80% 72%, rgba(46, 111, 87, 0.2), transparent 30%),
    linear-gradient(160deg, rgba(251, 252, 247, 0.9), rgba(226, 237, 226, 0.82));
  box-shadow: 0 28px 70px rgba(32, 47, 39, 0.1);
  overflow: auto;
}

.setup-sidebar h1 {
  max-width: 8em;
}

.setup-flow {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-top: 0;
}

.setup-flow span {
  position: relative;
  padding: 0.38rem 0.62rem;
  border-radius: 999px;
  color: #214f40;
  background: rgba(251, 252, 247, 0.64);
  font-weight: 850;
}

.setup-flow span::before {
  content: none;
}

.setup-panel {
  display: grid;
  gap: 1rem;
}

.setup-main {
  display: grid;
  gap: 0.65rem;
  min-height: auto;
  overflow: visible;
  padding-right: 0.25rem;
}

.setup-actions {
  display: grid;
  gap: 0.55rem;
  padding: 0.75rem;
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 1.1rem;
  background: rgba(251, 252, 247, 0.78);
  box-shadow: 0 18px 42px rgba(32, 47, 39, 0.08);
}

.setup-actions > button {
  width: 100%;
  min-width: 0;
}

.setup-health {
  color: #607069;
}

.setup-health summary {
  cursor: pointer;
  color: #214f40;
  font-weight: 850;
}

.setup-health .health-panel {
  margin: 0.8rem 0 0;
}

.eyebrow {
  margin: 0 0 0.45rem;
  color: #c46e44;
  font-size: 0.75rem;
  font-weight: 850;
  letter-spacing: 0.16em;
}

h1 {
  margin: 0;
  font-family: "Iowan Old Style", "STSong", "Songti SC", serif;
  font-size: clamp(2rem, 3.8vw, 3.1rem);
  line-height: 1;
}

.intro {
  max-width: 34rem;
  color: #5d6d66;
  line-height: 1.75;
}

.compact-intro {
  margin: 0;
  font-size: 0.92rem;
  line-height: 1.45;
}

.error {
  color: #a9462f;
}

.error-text {
  margin: 10px 0 0;
  color: #a9462f;
  font-size: 13px;
  line-height: 1.5;
}

.health-panel {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.7rem;
  margin: 1.2rem 0;
}

.training-dock {
  position: relative;
  z-index: 1;
  width: 100%;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  backdrop-filter: none;
}

.sidebar-card {
  background: rgba(251, 252, 247, 0.58);
  box-shadow: none;
}

.setup-card {
  display: grid;
  gap: 0.6rem;
  padding: clamp(0.72rem, 1.2vw, 1rem);
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 1.1rem;
  background: rgba(251, 252, 247, 0.82);
  box-shadow: 0 18px 48px rgba(32, 47, 39, 0.08);
}

.setup-card-head {
  display: flex;
  align-items: flex-start;
  gap: 0.65rem;
}

.setup-card-head > span {
  flex: 0 0 auto;
  display: grid;
  place-items: center;
  width: 2.2rem;
  height: 2.2rem;
  border-radius: 0.75rem;
  color: #fbfcf7;
  background: #214f40;
  font-weight: 900;
}

.setup-card-head strong {
  display: block;
  color: #214f40;
  font-size: 1.08rem;
}

.setup-card-head p {
  margin: 0.18rem 0 0;
  color: #607069;
  line-height: 1.35;
  font-size: 0.86rem;
}

.setup-grid {
  display: grid;
  gap: 0.75rem;
}

.setup-grid.two-cols {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.setup-grid.three-cols {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.config-field {
  display: grid;
  gap: 0.28rem;
}

.wide-field {
  grid-column: span 2;
}

.full-field {
  grid-column: 1 / -1;
}

.config-field span {
  color: #87948e;
  font-size: 0.72rem;
  font-weight: 850;
  letter-spacing: 0.08em;
}

.config-field select,
.config-field input {
  width: 100%;
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 0.75rem;
  padding: 0.7rem 0.75rem;
  color: #214f40;
  background: rgba(255, 255, 255, 0.68);
  font: inherit;
  font-weight: 750;
}

.inline-action-field {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 0.4rem;
}

.inline-action-field button {
  padding-inline: 0.85rem;
}

.job-picker {
  position: relative;
  isolation: isolate;
}

.job-picker input {
  padding-right: 2.4rem;
}

.job-picker:focus-within input {
  border-bottom-right-radius: 0;
  border-bottom-left-radius: 0;
}

.job-picker-toggle {
  position: absolute;
  top: 1px;
  right: 1px;
  bottom: 1px;
  display: grid;
  place-items: center;
  width: 2.2rem;
  border-radius: 0 0.72rem 0.72rem 0;
  padding: 0;
  color: #607069;
  background: transparent;
  box-shadow: none;
  font-size: 0.82rem;
}

.job-picker-toggle:hover {
  color: #214f40;
  background: rgba(33, 79, 64, 0.06);
}

.job-picker-menu {
  position: absolute;
  z-index: 20;
  left: 0;
  right: 0;
  top: 100%;
  display: grid;
  max-height: 13rem;
  overflow: auto;
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 0 0 0.75rem 0.75rem;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12px 24px rgba(32, 47, 39, 0.1);
  transform: translateY(-1px);
}

.job-picker-menu button {
  width: 100%;
  border-radius: 0;
  padding: 0.7rem 0.75rem;
  color: #214f40;
  background: transparent;
  text-align: left;
  font-weight: 750;
}

.job-picker-menu button:hover {
  background: rgba(33, 79, 64, 0.08);
}

.config-field select {
  min-height: 2.5rem;
}

.config-field select:disabled,
.config-field input:disabled {
  opacity: 0.68;
}

.file-upload-field {
  display: grid;
  gap: 0.45rem;
  padding: 0.65rem 0.8rem;
  border: 1px dashed rgba(33, 79, 64, 0.28);
  border-radius: 0.95rem;
  color: #214f40;
  background: rgba(255, 255, 255, 0.5);
  font-weight: 850;
}

.analysis-row {
  display: grid;
  grid-template-columns: minmax(14rem, 0.9fr) minmax(16rem, 1.1fr);
  gap: 0.8rem;
  align-items: stretch;
}

.analysis-row > button,
.analysis-row .file-upload-field {
  min-height: 3.4rem;
}

.compact-company-card,
.resume-preview-card,
.analysis-summary,
.mini-list {
  border: 1px solid rgba(33, 79, 64, 0.1);
  border-radius: 0.85rem;
  background: rgba(255, 255, 255, 0.52);
}

.compact-company-card {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 0.2rem 0.6rem;
  max-height: min(22rem, 48vh);
  overflow: auto;
  padding: 0.95rem 1rem;
  font-size: 1rem;
}

.compact-company-card strong {
  color: #214f40;
}

.compact-company-card span {
  color: #87948e;
  font-size: 0.78rem;
  font-weight: 800;
}

.compact-company-card p {
  grid-column: 1 / -1;
  margin: 0;
  color: #607069;
  line-height: 1.55;
  font-size: 0.98rem;
}

.company-detail-grid {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.45rem;
  margin-top: 0.35rem;
}

.company-summary-strip {
  display: grid;
  grid-template-columns: minmax(10rem, 0.9fr) minmax(0, 1.6fr) auto;
  gap: 0.8rem;
  align-items: center;
  width: 100%;
  border: 1px solid rgba(33, 79, 64, 0.14);
  border-radius: 0.85rem;
  padding: 0.75rem 0.85rem;
  color: #214f40;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.82), rgba(231, 242, 237, 0.68));
  box-shadow: 0 12px 32px rgba(33, 79, 64, 0.08);
  cursor: pointer;
  text-align: left;
}

.company-summary-strip span {
  display: grid;
  gap: 0.12rem;
  min-width: 0;
}

.company-summary-strip strong {
  overflow: hidden;
  color: #214f40;
  font-size: 0.98rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.company-summary-strip small {
  color: #75837d;
  font-size: 0.76rem;
  font-weight: 800;
}

.company-summary-strip em {
  overflow: hidden;
  color: #607069;
  font-size: 0.9rem;
  font-style: normal;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.company-summary-strip b {
  border-radius: 999px;
  padding: 0.35rem 0.62rem;
  color: #f6fbf8;
  background: #214f40;
  font-size: 0.78rem;
}

.company-summary-strip:hover {
  border-color: rgba(33, 79, 64, 0.28);
  transform: translateY(-1px);
}

.company-modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: grid;
  place-items: center;
  padding: clamp(0.7rem, 2vw, 1.25rem);
  background: rgba(17, 29, 25, 0.38);
  backdrop-filter: blur(18px) saturate(0.82);
  animation: companyOverlayIn 140ms ease-out both;
}

.company-modal {
  display: grid;
  grid-template-rows: auto auto minmax(0, 1fr);
  gap: 0.9rem;
  width: min(76rem, calc(100vw - 2rem));
  height: min(90vh, 56rem);
  max-height: calc(100vh - 1.5rem);
  overflow: auto;
  border: 1px solid rgba(33, 79, 64, 0.16);
  border-radius: 1.15rem;
  padding: 0;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(242, 248, 245, 0.96)),
    #fff;
  box-shadow: 0 28px 72px rgba(15, 32, 26, 0.25);
  animation: companyPanelIn 160ms ease-out both;
}

.company-modal header {
  position: sticky;
  top: 0;
  z-index: 1;
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 1rem;
  padding: 1.05rem 1.15rem 0.8rem;
  border-bottom: 1px solid rgba(33, 79, 64, 0.1);
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(10px);
}

.company-modal header span {
  color: #7a8a83;
  font-size: 0.76rem;
  font-weight: 850;
  text-transform: uppercase;
}

.company-modal h2 {
  margin: 0.1rem 0 0;
  color: #173c31;
  font-size: clamp(1.55rem, 2.2vw, 2.35rem);
}

.company-modal header p {
  margin: 0.25rem 0 0;
  color: #607069;
  font-size: 0.9rem;
  line-height: 1.45;
}

.company-modal header button {
  width: 2rem;
  height: 2rem;
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 50%;
  color: #214f40;
  background: rgba(255, 255, 255, 0.72);
  font-size: 1.2rem;
  line-height: 1;
  cursor: pointer;
}

.company-modal-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  padding: 0 1.15rem;
}

.company-modal-meta span {
  border-radius: 999px;
  padding: 0.32rem 0.62rem;
  color: #214f40;
  background: rgba(33, 79, 64, 0.1);
  font-size: 0.8rem;
  font-weight: 850;
}

.company-modal-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  align-content: start;
  gap: 0.7rem;
  min-height: 0;
  max-width: 58rem;
  width: 100%;
  margin: 0 auto;
  padding: 0 1.15rem 1.15rem;
}

.company-modal-summary-card {
  display: grid;
  gap: 0.35rem;
  padding: 0.8rem;
  border: 1px solid rgba(33, 79, 64, 0.1);
  border-radius: 0.8rem;
  background: rgba(255, 255, 255, 0.66);
}

.company-modal-summary-card strong {
  color: #214f40;
  font-size: 0.86rem;
}

.company-modal-summary-card p {
  margin: 0;
  color: #405049;
  font-size: 0.98rem;
  line-height: 1.65;
}

.company-modal .mini-list {
  min-height: auto;
  padding: 0.85rem 0.95rem;
  background: rgba(255, 255, 255, 0.66);
}

.company-modal .mini-list span {
  display: block;
}

.company-source-details {
  display: grid;
  gap: 0.28rem;
  padding: 0.45rem 0.6rem;
  border: 1px solid rgba(33, 79, 64, 0.08);
  border-radius: 0.65rem;
  color: #7a8a83;
  background: rgba(255, 255, 255, 0.38);
  font-size: 0.78rem;
}

.company-source-details summary {
  cursor: pointer;
  color: #607069;
  font-weight: 800;
}

.company-source-details span {
  display: block;
  color: #7a8a83;
  line-height: 1.42;
}

@keyframes companyOverlayIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes companyPanelIn {
  from {
    opacity: 0;
    transform: translateY(8px) scale(0.985);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.resume-preview-card {
  display: grid;
  gap: 0.35rem;
  padding: 0.65rem 0.75rem;
}

.resume-preview-card div {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.6rem;
}

.resume-preview-card strong {
  color: #214f40;
}

.resume-preview-card span {
  color: #87948e;
  font-size: 0.78rem;
  font-weight: 850;
}

.resume-preview-card p {
  max-height: 6.2rem;
  margin: 0;
  overflow: auto;
  color: #607069;
  line-height: 1.45;
  font-size: 0.86rem;
}

.analysis-result-card {
  gap: 0.5rem;
}

.analysis-summary {
  margin: 0;
  padding: 0.62rem 0.75rem;
  color: #405049;
  line-height: 1.4;
}

.analysis-mini-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
  gap: 0.55rem;
}

.mini-list {
  display: grid;
  gap: 0.28rem;
  min-height: 4.7rem;
  padding: 0.7rem 0.8rem;
}

.mini-list strong {
  color: #214f40;
  font-size: 0.82rem;
}

.mini-list span {
  color: #607069;
  font-size: 0.92rem;
  line-height: 1.42;
}

.file-upload-field input {
  color: #607069;
  font: inherit;
}

.company-card {
  padding: 0.85rem 1rem;
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 0.95rem;
  background: rgba(255, 255, 255, 0.58);
}

.company-card div {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.8rem;
}

.company-card strong {
  color: #214f40;
}

.company-card span {
  border-radius: 999px;
  padding: 0.28rem 0.58rem;
  color: #8f4b32;
  background: rgba(196, 110, 68, 0.12);
  font-size: 0.78rem;
  font-weight: 850;
}

.company-card span[data-status="partial"],
.company-card span[data-status="verified"] {
  color: #214f40;
  background: rgba(33, 79, 64, 0.1);
}

.company-card p {
  margin: 0.55rem 0;
  color: #405049;
  line-height: 1.65;
}

.company-card .source-warning {
  color: #8f4b32;
  font-weight: 760;
}

.company-card ul {
  display: grid;
  gap: 0.35rem;
  margin: 0;
  padding-left: 1.1rem;
  color: #607069;
}

.config-radar-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.55rem;
  min-height: 0;
}

.single-radar-grid {
  grid-template-columns: minmax(0, 1fr);
}

.single-radar-grid .config-radar-card {
  min-height: 18rem;
}

.single-radar-grid .config-radar-svg {
  width: min(100%, 19rem);
}

.config-radar-card {
  display: grid;
  justify-items: center;
  gap: 0.15rem;
  min-height: 15.2rem;
  padding: 0.35rem;
  border: 1px solid rgba(33, 79, 64, 0.1);
  border-radius: 1rem;
  background:
    radial-gradient(circle at 50% 40%, rgba(46, 111, 87, 0.08), transparent 54%),
    rgba(255, 255, 255, 0.52);
}

.config-radar-card .radar-title {
  align-items: flex-start;
}

.config-radar-card .radar-title span {
  max-width: 10rem;
  text-align: right;
  line-height: 1.45;
  font-size: 0.72rem;
}

.config-radar-svg {
  width: min(100%, 16.2rem);
  overflow: visible;
  touch-action: none;
}

.config-radar-svg .radar-baseline {
  fill: rgba(82, 154, 205, 0.14);
  stroke: rgba(82, 154, 205, 0.55);
  stroke-width: 2;
}

.config-radar-svg .radar-area {
  fill: rgba(46, 145, 103, 0.24);
  stroke: #2e9167;
}

.draggable-dot {
  cursor: grab;
  fill: #2e9167;
}

.draggable-dot:active {
  cursor: grabbing;
}

.radar-legend {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.45rem;
  color: #607069;
  font-size: 0.75rem;
  font-weight: 820;
}

.radar-legend span {
  position: relative;
  padding-left: 0.9rem;
}

.radar-legend span::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.35rem;
  width: 0.5rem;
  height: 0.5rem;
  border-radius: 999px;
  background: #529acd;
}

.radar-legend .legend-current::before {
  background: #2e9167;
}

.voice-control-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.65rem;
  padding: 0.55rem;
  border: 1px solid rgba(33, 79, 64, 0.1);
  border-radius: 1rem;
  background: rgba(255, 255, 255, 0.45);
}

.style-weights {
  display: grid;
  gap: 0.55rem;
  padding: 0.85rem 1rem;
  border: 1px solid rgba(33, 79, 64, 0.1);
  border-radius: 0.95rem;
  background: rgba(255, 255, 255, 0.48);
}

.style-weights p {
  margin: 0;
  color: #214f40;
  font-weight: 850;
}

.style-weights label {
  display: grid;
  grid-template-columns: 5.5rem 1fr 3rem;
  gap: 0.75rem;
  align-items: center;
  color: #607069;
  font-size: 0.86rem;
  font-weight: 760;
}

.style-weights input {
  accent-color: #214f40;
}

.health-panel div {
  position: relative;
  min-height: 4.7rem;
  padding: 0.85rem 0.9rem 0.85rem 2rem;
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 0.85rem;
  background: rgba(255, 255, 255, 0.48);
}

.health-panel strong {
  display: block;
  margin-bottom: 0.2rem;
  color: #214f40;
}

.health-panel p {
  margin: 0;
  color: #607069;
  font-size: 0.9rem;
  line-height: 1.45;
}

.health-dot {
  position: absolute;
  top: 1rem;
  left: 0.85rem;
  width: 0.62rem;
  height: 0.62rem;
  border-radius: 999px;
  background: #b85d43;
  box-shadow: 0 0 0 0.25rem rgba(184, 93, 67, 0.1);
}

.health-dot[data-ok="true"] {
  background: #2e6f57;
  box-shadow: 0 0 0 0.25rem rgba(46, 111, 87, 0.11);
}

.connection-row {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  color: #405049;
}

.connection-row .health-dot {
  position: static;
  flex: 0 0 auto;
}

.connection-row p {
  margin: 0;
}

.room-shell {
  display: grid;
  grid-template-rows: auto 1fr auto;
  gap: 1rem;
}

.call-layout {
  max-width: 920px;
}

.room-header {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: center;
}

.call-header h1 {
  font-size: clamp(1.6rem, 3vw, 2.8rem);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 0.7rem;
}

.pill {
  max-width: 16rem;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  border-radius: 999px;
  padding: 0.45rem 0.8rem;
  color: #214f40;
  background: rgba(251, 252, 247, 0.78);
  font-size: 0.85rem;
  font-weight: 700;
}

.voice-stage {
  display: grid;
  place-items: center;
  align-content: center;
  gap: 1rem;
  min-height: 32rem;
  border: 1px solid rgba(33, 79, 64, 0.16);
  border-radius: 1.2rem;
  background:
    radial-gradient(circle at 50% 40%, rgba(47, 111, 88, 0.15), transparent 32%),
    rgba(251, 252, 247, 0.78);
  box-shadow: 0 28px 70px rgba(32, 47, 39, 0.1);
}

.call-stage {
  position: relative;
  min-height: min(72vh, 48rem);
  display: grid;
  place-items: center;
  align-content: center;
  gap: clamp(1.2rem, 4vh, 2.4rem);
  overflow: hidden;
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 2rem;
  background:
    radial-gradient(circle at 50% 22%, rgba(226, 239, 225, 0.95), transparent 26%),
    radial-gradient(circle at 20% 80%, rgba(196, 110, 68, 0.12), transparent 28%),
    linear-gradient(160deg, rgba(251, 252, 247, 0.9), rgba(218, 231, 220, 0.88));
  box-shadow: 0 32px 90px rgba(32, 47, 39, 0.13);
}

.call-backdrop {
  position: absolute;
  inset: 12%;
  border-radius: 999px;
  background:
    repeating-radial-gradient(circle, rgba(33, 79, 64, 0.08) 0 1px, transparent 1px 22px),
    radial-gradient(circle, rgba(33, 79, 64, 0.12), transparent 58%);
  filter: blur(0.5px);
  opacity: 0.75;
  pointer-events: none;
}

.call-persona {
  position: relative;
  z-index: 1;
  display: grid;
  place-items: center;
  gap: 0.85rem;
  text-align: center;
}

.call-avatar {
  position: relative;
  width: clamp(12rem, 28vw, 17rem);
  height: clamp(12rem, 28vw, 17rem);
  display: grid;
  place-items: center;
}

.avatar-core {
  position: relative;
  z-index: 2;
  width: 58%;
  height: 58%;
  display: grid;
  place-items: center;
  border-radius: 999px;
  color: #fbfcf7;
  background:
    radial-gradient(circle at 38% 28%, rgba(255, 255, 255, 0.35), transparent 18%),
    linear-gradient(145deg, #214f40, #2d715b);
  box-shadow:
    inset 0 0 0 1px rgba(255, 255, 255, 0.18),
    0 26px 62px rgba(33, 79, 64, 0.24);
}

.avatar-core span {
  font-family: "Iowan Old Style", "STSong", "Songti SC", serif;
  font-size: clamp(2.4rem, 6vw, 4.4rem);
  font-weight: 850;
}

.avatar-ring {
  position: absolute;
  inset: 12%;
  border-radius: 999px;
  border: 1px solid rgba(33, 79, 64, 0.16);
  background: rgba(251, 252, 247, 0.26);
}

.ring-two {
  inset: 0;
  opacity: 0.5;
}

.call-avatar[data-phase="speaking"] .ring-one,
.call-avatar[data-phase="listening"] .ring-one {
  animation: callPulse 1.8s ease-out infinite;
}

.call-avatar[data-phase="speaking"] .ring-two,
.call-avatar[data-phase="listening"] .ring-two {
  animation: callPulse 1.8s ease-out infinite 0.55s;
}

.call-status-minimal {
  margin: 0;
  min-height: 1.6rem;
  color: #6a7a73;
  font-size: 0.95rem;
  font-weight: 750;
  letter-spacing: 0.08em;
}

.user-wave {
  position: relative;
  z-index: 1;
  --voice-level: 0;
  width: min(72vw, 24rem);
  height: 4.6rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.35rem;
  padding: 0.9rem 1rem;
  border-radius: 999px;
  background: rgba(251, 252, 247, 0.44);
  box-shadow: inset 0 0 0 1px rgba(33, 79, 64, 0.08);
  backdrop-filter: blur(14px);
}

.user-wave span {
  width: 0.32rem;
  height: calc(0.55rem + var(--voice-level) * 2.2rem);
  min-height: 0.55rem;
  border-radius: 999px;
  background: linear-gradient(180deg, #2d715b, #9fb9aa);
  opacity: 0.35;
  transform: scaleY(0.75);
  transition: height 120ms ease, opacity 160ms ease, transform 160ms ease;
}

.user-wave[data-active="true"] span {
  opacity: 0.82;
  animation: waveIdle 1.1s ease-in-out infinite;
}

.user-wave[data-active="true"] span:nth-child(2n) {
  animation-delay: 0.12s;
}

.user-wave[data-active="true"] span:nth-child(3n) {
  animation-delay: 0.24s;
}

.user-wave[data-active="true"] span:nth-child(5n) {
  animation-delay: 0.36s;
}

.call-controls {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.9rem;
}

.call-control {
  min-width: 6.2rem;
  min-height: 3.5rem;
  padding: 0.9rem 1.25rem;
  color: #214f40;
  background: rgba(251, 252, 247, 0.78);
  box-shadow:
    inset 0 0 0 1px rgba(33, 79, 64, 0.1),
    0 12px 34px rgba(32, 47, 39, 0.08);
}

.primary-call {
  color: #fbfcf7;
  background: #214f40;
}

.end-call {
  color: #fff9f4;
  background: #b64a3a;
}

.call-note {
  position: relative;
  z-index: 1;
  max-width: 34rem;
  margin: 0;
  color: #87948e;
  font-size: 0.78rem;
  line-height: 1.6;
  text-align: center;
}

.compact-controls {
  display: none;
}

@keyframes callPulse {
  0% {
    transform: scale(0.92);
    opacity: 0.58;
  }
  100% {
    transform: scale(1.12);
    opacity: 0;
  }
}

@keyframes waveIdle {
  0%,
  100% {
    transform: scaleY(0.72);
  }
  50% {
    transform: scaleY(1.18);
  }
}

.orb {
  width: 13rem;
  height: 13rem;
  display: grid;
  place-items: center;
  border-radius: 999px;
  background: linear-gradient(145deg, #dce9df, #f8fbf4);
  box-shadow:
    inset 0 0 0 1px rgba(47, 111, 88, 0.13),
    0 18px 48px rgba(47, 111, 88, 0.16);
}

.lk-audio-bar {
  background: #214f40;
}

.voice-stage[data-state*="speaking"] .orb {
  box-shadow:
    inset 0 0 0 1px rgba(40, 77, 120, 0.18),
    0 18px 52px rgba(40, 77, 120, 0.2);
}

.voice-stage[data-state*="speaking"] .lk-audio-bar {
  background: #284d78;
}

.status {
  margin: 0;
  font-size: clamp(1.45rem, 3vw, 2.1rem);
  font-weight: 750;
}

.hint {
  max-width: 34rem;
  margin: 0;
  color: #607069;
  line-height: 1.7;
  text-align: center;
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.7rem;
}

.transcript-card {
  width: min(100%, 38rem);
  padding: 0.9rem 1rem;
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 0.85rem;
  background: rgba(251, 252, 247, 0.78);
}

.transcript-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.8rem;
  width: min(100%, 48rem);
}

.transcript-grid .transcript-card {
  width: 100%;
  min-height: 8rem;
}

.history-card {
  width: min(100%, 48rem);
  padding: 0.9rem 1rem;
  border: 1px solid rgba(33, 79, 64, 0.12);
  border-radius: 0.85rem;
  background: rgba(251, 252, 247, 0.72);
}

.report-card {
  width: 100%;
  padding: clamp(1.1rem, 2.4vw, 2rem);
  border: 1px solid rgba(33, 79, 64, 0.14);
  border-radius: 1.25rem;
  background: rgba(251, 252, 247, 0.84);
  box-shadow: 0 22px 60px rgba(32, 47, 39, 0.09);
}

.compact-report {
  position: relative;
  z-index: 1;
  width: min(100%, 48rem);
  max-height: 18rem;
  overflow: auto;
  box-shadow: 0 18px 50px rgba(32, 47, 39, 0.1);
}

.report-summary {
  margin: 0 0 0.8rem;
  color: #405049;
  line-height: 1.65;
}

.fit-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
  margin: 0 0 1rem;
}

.fit-card {
  padding: 0.85rem;
  border-radius: 0.85rem;
  background: rgba(255, 255, 255, 0.58);
}

.fit-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  margin-bottom: 0.45rem;
}

.fit-head strong {
  color: #214f40;
}

.fit-head span {
  color: #c46e44;
  font-weight: 900;
}

.fit-card p,
.fit-card small {
  display: block;
  margin: 0.35rem 0 0;
  color: #405049;
  line-height: 1.55;
}

.fit-card small {
  color: #87948e;
  font-weight: 760;
}

.mini-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-top: 0.55rem;
}

.mini-tags span {
  border-radius: 999px;
  padding: 0.24rem 0.55rem;
  color: #214f40;
  background: rgba(33, 79, 64, 0.08);
  font-size: 0.76rem;
  font-weight: 820;
}

.report-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  margin: -0.25rem 0 0.75rem;
}

.report-meta span {
  border-radius: 999px;
  padding: 0.28rem 0.62rem;
  color: #214f40;
  background: rgba(33, 79, 64, 0.08);
  font-size: 0.78rem;
  font-weight: 800;
}

.ability-bars {
  display: grid;
  gap: 0.55rem;
  margin: 0 0 0.85rem;
  padding: 0.8rem;
  border-radius: 0.85rem;
  background: rgba(255, 255, 255, 0.56);
}

.radar-card {
  display: grid;
  justify-items: center;
  gap: 0.35rem;
  margin: 0 0 0.85rem;
  padding: 0.85rem;
  border-radius: 0.85rem;
  background:
    radial-gradient(circle at 50% 50%, rgba(46, 111, 87, 0.08), transparent 56%),
    rgba(255, 255, 255, 0.58);
}

.radar-title {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  color: #214f40;
}

.radar-title span {
  color: #87948e;
  font-size: 0.78rem;
  font-weight: 850;
}

.radar-card svg {
  width: min(100%, 18rem);
  max-height: 18rem;
  overflow: visible;
}

.radar-grid {
  fill: none;
  stroke: rgba(33, 79, 64, 0.13);
  stroke-width: 1;
}

.radar-axis {
  stroke: rgba(33, 79, 64, 0.12);
  stroke-width: 1;
}

.radar-area {
  fill: rgba(196, 110, 68, 0.22);
  stroke: #c46e44;
  stroke-width: 2.5;
  filter: drop-shadow(0 8px 18px rgba(196, 110, 68, 0.16));
}

.radar-dot {
  fill: #214f40;
  stroke: #fbfcf7;
  stroke-width: 2;
}

.radar-label {
  fill: #405049;
  font-size: 0.7rem;
  font-weight: 850;
}

.ability-row {
  display: grid;
  grid-template-columns: 5.5rem 1fr 2.6rem;
  gap: 0.65rem;
  align-items: center;
  color: #405049;
  font-size: 0.86rem;
}

.ability-row span,
.ability-row b {
  font-weight: 850;
}

.ability-track {
  height: 0.52rem;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(33, 79, 64, 0.1);
}

.ability-track i {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #c46e44, #2e6f57);
}

.gap-card {
  margin: 0 0 0.8rem;
  padding: 0.8rem;
  border-radius: 0.75rem;
  background: rgba(196, 110, 68, 0.1);
}

.gap-card b {
  color: #8f4b32;
}

.gap-card ul {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  margin: 0.55rem 0 0;
  padding: 0;
  list-style: none;
}

.gap-card li {
  border-radius: 999px;
  padding: 0.3rem 0.6rem;
  color: #8f4b32;
  background: rgba(255, 255, 255, 0.58);
  font-size: 0.82rem;
  font-weight: 760;
}

.score-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
}

.score-card,
.plan-card {
  padding: 0.8rem;
  border-radius: 0.75rem;
  background: rgba(255, 255, 255, 0.56);
}

.score-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  margin-bottom: 0.45rem;
}

.score-head strong {
  color: #214f40;
}

.score-head span {
  color: #c46e44;
  font-weight: 900;
}

.score-card p,
.plan-card p {
  margin: 0.35rem 0 0;
  color: #405049;
  line-height: 1.55;
}

.plan-card {
  margin-top: 0.75rem;
}

.task-list {
  display: grid;
  gap: 0.55rem;
  margin-top: 0.55rem;
}

.task-list article {
  padding: 0.65rem;
  border-radius: 0.65rem;
  background: rgba(33, 79, 64, 0.06);
}

.task-list strong {
  color: #214f40;
}

.task-list small {
  display: block;
  margin-top: 0.35rem;
  color: #8f4b32;
  font-weight: 800;
}

.phase-plan {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.65rem;
  margin-top: 0.75rem;
}

.phase-plan article {
  padding: 0.7rem;
  border-radius: 0.75rem;
  background: rgba(196, 110, 68, 0.08);
}

.phase-plan strong {
  color: #8f4b32;
}

.phase-plan ul {
  display: grid;
  gap: 0.35rem;
  margin: 0.45rem 0 0;
  padding-left: 1rem;
  color: #405049;
  line-height: 1.5;
}

.history-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  margin-bottom: 0.55rem;
}

.history-title span,
.history-card time {
  color: #87948e;
  font-size: 0.78rem;
}

.history-card ul {
  display: grid;
  gap: 0.55rem;
  max-height: 16rem;
  margin: 0;
  padding: 0;
  overflow: auto;
  list-style: none;
}

.history-card li {
  display: grid;
  grid-template-columns: 2.4rem 1fr auto;
  gap: 0.65rem;
  align-items: start;
  padding: 0.6rem 0.7rem;
  border-radius: 0.65rem;
  background: rgba(255, 255, 255, 0.48);
}

.history-card li span {
  color: #c46e44;
  font-weight: 850;
}

.history-card li p,
.history-card .empty {
  margin: 0;
  color: #405049;
  line-height: 1.55;
}

.debug-card {
  width: min(100%, 38rem);
  color: #607069;
  font-size: 0.85rem;
}

.debug-card summary {
  cursor: pointer;
  font-weight: 800;
}

.debug-card ul {
  display: grid;
  gap: 0.35rem;
  margin: 0.6rem 0 0;
  padding: 0;
  list-style: none;
}

.debug-card li {
  padding: 0.45rem 0.6rem;
  border-radius: 0.5rem;
  background: rgba(251, 252, 247, 0.72);
}

.transcript-card p {
  margin: 0;
  line-height: 1.65;
}

.transcript-card .label {
  margin-bottom: 0.35rem;
  color: #c46e44;
  font-size: 0.75rem;
  font-weight: 850;
  letter-spacing: 0.12em;
}

.controls {
  padding: 0.9rem;
  border: 1px solid rgba(33, 79, 64, 0.14);
  border-radius: 1rem;
  background: rgba(251, 252, 247, 0.72);
}

@media (max-width: 720px) {
  .home-hero,
  .wizard-shell {
    grid-template-columns: 1fr;
  }

  .home-hero {
    display: grid;
  }

  .home-workspace,
  .home-grid,
  .home-grid.two-columns,
  .choice-grid,
  .confirm-grid {
    grid-template-columns: 1fr;
  }

  .home-nav-card {
    position: static;
    min-height: auto;
  }

  .home-focus-card {
    min-height: auto;
  }

  .history-list button,
  .history-list div {
    grid-template-columns: 1fr;
  }

  .setup-grid.two-cols,
  .setup-grid.three-cols {
    grid-template-columns: 1fr;
  }

  .setup-page {
    height: auto;
    overflow: visible;
  }

  .setup-sidebar,
  .setup-main {
    overflow: visible;
  }

  .setup-sidebar {
    min-height: auto;
  }

  .setup-actions {
    display: grid;
  }

  .setup-actions > button {
    width: 100%;
  }

  .room-header {
    display: grid;
  }

  .header-actions {
    justify-content: space-between;
  }

  .voice-stage {
    min-height: 25rem;
  }

  .call-stage {
    min-height: 70vh;
    border-radius: 1.35rem;
  }

  .health-panel,
  .training-dock,
  .analysis-row,
  .company-summary-strip,
  .company-detail-grid,
  .company-modal-layout,
  .config-radar-grid,
  .voice-control-grid,
  .transcript-grid,
  .fit-grid,
  .phase-plan,
  .score-grid {
    grid-template-columns: 1fr;
  }

  .history-card li {
    grid-template-columns: 2.4rem 1fr;
  }

  .history-card time {
    grid-column: 2;
  }

  .company-modal-backdrop {
    align-items: stretch;
    padding: 0.75rem;
  }

  .company-modal {
    width: 100%;
    height: calc(100vh - 1.5rem);
    max-height: calc(100vh - 1.5rem);
  }

  .company-modal header,
  .company-modal-meta,
  .company-modal-layout {
    padding-left: 0.8rem;
    padding-right: 0.8rem;
  }
}
